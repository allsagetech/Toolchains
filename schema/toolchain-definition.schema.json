{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.allsagetech.com/toolchain/v1/toolchain-definition.schema.json",
  "title": "Toolchain package definition (.tlc/.pwr)",
  "description": "Version 1 of the Toolchain package-definition contract. The OCI image label io.allsagetech.toolchain.specVersion selects this contract version.",
  "x-toolchain-spec-version": 1,
  "type": "object",
  "required": [
    "env"
  ],
  "properties": {
    "env": {
      "type": "object",
      "propertyNames": {
        "pattern": "\\S"
      },
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          {
            "type": "null"
          }
        ]
      }
    }
  },
  "additionalProperties": {
    "type": "object",
    "required": [
      "env"
    ],
    "properties": {
      "env": {
        "type": "object",
        "propertyNames": {
          "pattern": "\\S"
        },
        "additionalProperties": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "additionalProperties": true
  },
  "$comment": "Toolchain - Copyright (c) 2026 AllSageTech - SPDX-License-Identifier: MPL-2.0"
}
